  .final h2{font-size:clamp(24px,3vw,32px);margin-bottom:14px;color:#fff;}
  .final p{color:rgba(255,255,255,0.7);max-width:460px;margin:0 auto 28px;font-size:14.5px;}
  .price{font-family:var(--font-display);font-size:40px;color:var(--accent-teal);margin-bottom:6px;}
  .price small{font-size:14px;color:rgba(255,255,255,0.6);font-family:var(--font-body);}

  #paymentBrick_container{
    position:relative;z-index:1;max-width:440px;margin:0 auto;
    text-align:left;background:#fff;border-radius:12px;padding:4px;
  }
  .payment-result{
    position:relative;z-index:1;max-width:440px;margin:16px auto 0;
    font-size:13px;text-align:left;padding:0 2px;color:rgba(255,255,255,0.85);
  }
  .payment-result.is-ok{color:var(--accent-teal);}
  .payment-result.is-pending{color:#ffcf7a;}
  .payment-result.is-error{color:#ff8fa8;}

  footer{
    padding:30px 0;color:var(--text-dim);font-size:12.5px;
    display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;
  }

  @media (max-width:760px){
    .hero__grid{grid-template-columns:1fr;}
    .pilar-grid{grid-template-columns:1fr;}
    .access-grid{grid-template-columns:1fr;}
    .diag-row{grid-template-columns:1fr;gap:10px;}
    .final{padding:36px 22px;}
  }
</style>
