  .diag-row p strong{color:var(--text-primary);font-weight:600;}

  /* ---------- pilares (era method-grid) ---------- */
  .pilar-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  .pilar{
    background:var(--bg-panel);border:1px solid var(--line);
    border-radius:16px;padding:30px 26px;
  }
  .pilar__num{font-size:12px;letter-spacing:0.1em;color:var(--text-dim);margin-bottom:16px;font-weight:600;}
  .pilar__icon{
    width:44px;height:44px;border-radius:12px;
    display:flex;align-items:center;justify-content:center;
    margin-bottom:18px;
  }
  .pilar:nth-child(1) .pilar__icon{background:var(--accent-teal-soft);}
  .pilar:nth-child(2) .pilar__icon{background:var(--accent-pink-soft);}
  .pilar:nth-child(3) .pilar__icon{background:#fff4e0;}
  .pilar h3{font-size:20px;margin-bottom:10px;color:var(--bg-navy);}
  .pilar p{color:var(--text-dim);font-size:14.5px;}

  /* ---------- toc ---------- */
  .toc{
    border:1px solid var(--line);background:var(--bg-panel);
    border-radius:16px;overflow:hidden;font-size:14px;
  }
  .toc__bar{
    display:flex;justify-content:space-between;
    padding:14px 24px;background:var(--bg-navy);color:#fff;
    font-size:11.5px;letter-spacing:0.08em;
