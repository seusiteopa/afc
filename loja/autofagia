  }
  .cta-btn:hover{transform:translateY(-2px);box-shadow:0 10px 26px rgba(31,178,166,0.36);}
  .cta-btn::after{content:"→";}
  .cta-note{margin-top:14px;font-size:13px;color:var(--text-dim);}

  .hero__visual{
    background:var(--bg-panel);
    border:1px solid var(--line);
    border-radius:20px;
    padding:32px;
    box-shadow:0 20px 50px rgba(18,41,63,0.06);
