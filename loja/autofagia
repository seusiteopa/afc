  .eyebrow{
    font-size:12px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--accent-teal);
    font-weight:600;
    display:flex;align-items:center;gap:8px;
    margin-bottom:16px;
  }
  .eyebrow::before{
