  .back-link{font-size:13px;color:var(--text-dim);display:flex;align-items:center;gap:6px;}
  .badge-live{
    font-size:11px;letter-spacing:0.08em;color:var(--accent-teal);
    background:var(--accent-teal-soft);
    padding:6px 12px;border-radius:20px;
    display:flex;align-items:center;gap:8px;font-weight:600;
  }
  .badge-live::before{
    content:"";width:6px;height:6px;border-radius:50%;background:var(--accent-teal);
    animation:pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.3;}}

  /* ---------- hero ---------- */
