  .toc__row:last-child{border-bottom:none;}
  .toc__name{display:flex;gap:14px;align-items:baseline;color:var(--text-primary);font-weight:500;}
  .toc__name .num{color:var(--accent-teal);font-weight:700;}
  .toc__meta{color:var(--text-dim);white-space:nowrap;font-size:13.5px;}

  /* ---------- access control ---------- */
  .access-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  .access-col{
    background:var(--bg-panel);border:1px solid var(--line);
    border-radius:16px;padding:28px;
  }
  .access-col h3{font-size:15px;margin-bottom:18px;display:flex;align-items:center;gap:10px;color:var(--bg-navy);}
  .access-col ul{list-style:none;display:flex;flex-direction:column;gap:12px;}
  .access-col li{font-size:14.5px;color:var(--text-dim);display:flex;gap:10px;}
  .access-col.granted li::before{content:"✓";color:var(--accent-teal);font-weight:700;}
  .access-col.denied li::before{content:"×";color:var(--text-dim);font-weight:700;}

  /* ---------- disclaimer ---------- */
  .disclaimer{
    background:#fff8ec;border:1px solid #f0dfb8;
    border-radius:12px;padding:20px 24px;
    font-size:13.5px;color:#6b5a30;margin-top:24px;
  }
  .disclaimer strong{color:#5a4a20;}

  /* ---------- final cta ---------- */
