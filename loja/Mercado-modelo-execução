    const html = `
      <p>Pagamento Pix gerado! Escaneie o QR Code ou copie o código abaixo no app do seu banco:</p>
      ${pix.qr_code_base64 ? `<img src="data:image/png;base64,${pix.qr_code_base64}" alt="QR Code Pix" style="width:180px;height:180px;display:block;margin:12px 0;border:1px solid var(--line);background:#fff;">` : ''}
      ${pix.qr_code ? `
        <textarea readonly rows="3" style="width:100%;font-size:11px;background:var(--bg-panel-2);color:var(--text-dim);border:1px solid var(--line);padding:8px;margin-bottom:8px;font-family:var(--font-mono);" onclick="this.select()">${pix.qr_code}</textarea>
        <button type="button" id="copyPixBtn" class="cta-btn" style="font-size:12px;padding:8px 14px;">Copiar código Pix</button>
      ` : ''}
      <p style="margin-top:12px;">Depois de pagar, a confirmação chega automaticamente por e-mail.</p>
    `;
    showResult(html, 'pending');

    const btn = document.getElementById('copyPixBtn');
    if (btn){
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(pix.qr_code).then(() => {
          btn.textContent = 'Copiado!';
          setTimeout(() => { btn.textContent = 'Copiar código Pix'; }, 2000);
        });
      });
    }
  }

  bricksBuilder.create('payment', 'paymentBrick_container', {
    initialization: {
      amount: 37.00, // valor só pra exibição do formulário — quem decide o valor cobrado de verdade é o backend
    },
    customization: {
      visual: { style: { theme: 'dark' } },
      paymentMethods: {
        creditCard: 'all',
        debitCard: 'all',
        bankTransfer: 'all', // Pix
        ticket: 'all',       // boleto
      },
    },
    callbacks: {
      onReady: () => {
        // formulário pronto
      },
      onSubmit: ({ selectedPaymentMethod, formData }) => {
        return new Promise((resolve) => {
          const customerPhone = document.getElementById('customerPhone')?.value || '';

          if (!customerPhone.trim()) {
            showResult('Por favor, preencha seu WhatsApp antes de continuar.', 'error');
            resolve();
            return;
          }

          showResult('Processando pagamento...', 'pending');
          fetch('/.netlify/functions/create-payment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              product_slug: PRODUCT_SLUG,
              formData,
              customer_phone: customerPhone,
            }),
          })
            .then((response) => response.json())
            .then((data) => {
              if (data.status === 'approved') {
                showResult('Pagamento aprovado! Você vai receber o e-book por e-mail em alguns instantes.', 'ok');
              } else if (data.status === 'pending' && data.pix) {
                showPixResult(data.pix);
              } else if (data.status === 'pending') {
                showResult('Pagamento em processamento (normal em boleto). A confirmação chega por e-mail.', 'pending');
              } else if (data.error) {
                showResult('Não foi possível processar: ' + data.error, 'error');
              } else {
                showResult('Pagamento recusado. Tente outro cartão ou meio de pagamento.', 'error');
              }
              resolve();
            })
            .catch((error) => {
              console.error(error);
              showResult('Erro de conexão ao processar o pagamento. Tente novamente.', 'error');
              resolve();
            });
        });
      },
      onError: (error) => {
        console.error(error);
        showResult('Algo deu errado ao carregar o formulário. Confira se a Public Key está certa.', 'error');
      },
    },
  });

  // clock
  const clockEl = document.getElementById('scanClock');
  function tick(){
    const d = new Date();
    const p = n => String(n).padStart(2,'0');
    clockEl.textContent = `${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`;
  }
  tick(); setInterval(tick, 1000);

  // scanner status cycle
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const tagEl = document.getElementById('scanTag');
  const barEl = document.getElementById('scanBar');
  const stages = [
    {label:'MEDINDO MERCADO...', color:'var(--accent-amber)', width:'30%'},
    {label:'CRUZANDO MODELO...', color:'var(--accent-cyan)', width:'65%'},
    {label:'EXECUÇÃO VALIDADA ✓', color:'var(--accent-magenta)', width:'100%'}
  ];
  let i = 0;
  function setStage(idx){
    const s = stages[idx];
    tagEl.textContent = s.label;
    tagEl.style.color = s.color;
    barEl.style.width = s.width;
    barEl.style.background = s.color;
  }
  setStage(0);
  if(!reduce){
    setInterval(()=>{ i = (i+1) % stages.length; setStage(i); }, 2600);
  }
</script>

</body>
</html>
